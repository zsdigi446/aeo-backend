# ===== 后端环境变量示例（复制为 .env 使用，.env 已被 gitignore 忽略） =====

# --- 微信支付（选填；不配置则自动回退到演示/模拟支付） ---
WX_PAY_ENABLED=false
WX_MCH_ID=
WX_APP_ID=
WX_API_V3_KEY=
WX_SERIAL_NO=
WX_PRIVATE_KEY=
WX_PAY_NOTIFY_URL=
WX_PAY_AMOUNT=9900
WX_PRODUCT_DESC=AEO网站完整分析报告

# --- Supabase 持久化（选填；不配置则回退本地 JSON 文件 data/） ---
# SUPABASE_URL 形如 https://xxxxxxxx.supabase.co
# SUPABASE_KEY 用 service_role key（服务端专用，绕过 RLS），切勿用 anon key
# 需先建表：见仓库说明 / SQL 脚本
SUPABASE_URL=
SUPABASE_KEY=
